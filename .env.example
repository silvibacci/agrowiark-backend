# AgrowIArk — Variables de entorno
# Copiar este archivo como .env y completar los valores

# Entorno (development | production)
ENVIRONMENT=development

# Puerto del servidor
PORT=8000

# CORS: dominios permitidos en producción (separados por coma)
# En development se permite todo (*)
ALLOWED_ORIGINS=http://localhost:3000,https://tudominio.com

# ── Servicios satelitales ─────────────────────────────────────────────────────
# Microsoft Planetary Computer: no requiere API key para uso público
# No agregar nada aquí por ahora.

# ── IA — Resumen en lenguaje natural (Fase 2) ─────────────────────────────────
# Groq API (plan gratuito — https://console.groq.com)
# GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Alternativa: Google Gemini Flash (gratuito — https://aistudio.google.com)
# GEMINI_API_KEY=AIzaxxxxxxxxxxxx

# ── Base de datos (Fase 2) ────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/agrowIArk

# ── Stripe (Fase 2 — pagos) ───────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
